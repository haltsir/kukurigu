<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Kukurigu" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Dedicated theme for the full-screen alarm shown over the lock screen.
         A dark window background prevents a white flash before Compose draws,
         and Compose's KukuriguTheme Surface paints the final colors. -->
    <style name="Theme.Kukurigu.Alarm" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/ic_launcher_background</item>
        <item name="android:windowShowWallpaper">false</item>
    </style>
</resources>
